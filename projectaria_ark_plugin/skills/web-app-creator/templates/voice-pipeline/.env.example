# =====================================================================
# Voice pipeline — only ONE of the schemes below is required
# =====================================================================

# ──────────────────────────────────────────────────────────────────────
# Scheme A: Single OpenAI key (simplest)
#   Used for both STT (Whisper) AND chat (GPT)
# ──────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com   # optional override

# ──────────────────────────────────────────────────────────────────────
# Scheme B: Mix providers — Whisper + Claude (recommended)
#   STT must be OpenAI-compatible (Anthropic doesn't offer STT)
#   LLM uses Anthropic Claude
# ──────────────────────────────────────────────────────────────────────
# STT_API_KEY=sk-...                       # OpenAI / Groq / Azure / etc.
# STT_BASE_URL=https://api.openai.com      # optional, default OpenAI
# STT_MODEL=whisper-1                      # optional, default whisper-1
#
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_PROVIDER=anthropic                   # optional explicit
# LLM_MODEL=claude-sonnet-4-20250514       # optional

# ──────────────────────────────────────────────────────────────────────
# Scheme C: Fully local / self-hosted
#   STT  → whisper.cpp server  (http://localhost:8080)
#   LLM  → Ollama / LM Studio  (OpenAI-compatible endpoint)
# ──────────────────────────────────────────────────────────────────────
# STT_BASE_URL=http://localhost:8080
# STT_API_KEY=anything
# STT_MODEL=whisper-1
#
# LLM_PROVIDER=openai
# LLM_BASE_URL=http://localhost:11434/v1   # Ollama OpenAI-compatible
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.1

# ──────────────────────────────────────────────────────────────────────
# Scheme D: Manus / Forge backwards compatibility
#   These are auto-detected as fallbacks; nothing else needed.
# ──────────────────────────────────────────────────────────────────────
# BUILT_IN_FORGE_API_KEY=...
# BUILT_IN_FORGE_API_URL=https://forge.example.com

# ──────────────────────────────────────────────────────────────────────
# Server config
# ──────────────────────────────────────────────────────────────────────
# PORT=8000
